{
  "@context": {
    "@version": 1.1,
    "bfe": "https://bfe-networks.net/schema/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "MonitorCategoriesResponse": "bfe:MonitorCategoriesResponse",
    "MonitorMetricsResponse": "bfe:MonitorMetricsResponse",
    "ReloadEntriesResponse": "bfe:ReloadEntriesResponse",
    "ReloadEntry": "bfe:ReloadEntry",
    "ReloadResponse": "bfe:ReloadResponse",
    "categories": {
      "@id": "bfe:categories",
      "@type": "xsd:string"
    },
    "name": {
      "@id": "bfe:name",
      "@type": "xsd:string"
    },
    "metrics": {
      "@id": "bfe:metrics",
      "@type": "xsd:string"
    },
    "entries": {
      "@id": "bfe:entries",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "bfe:description",
      "@type": "xsd:string"
    },
    "success": {
      "@id": "bfe:success",
      "@type": "xsd:boolean"
    },
    "message": {
      "@id": "bfe:message",
      "@type": "xsd:string"
    }
  }
}